# Local-only artifacts that should never enter the image.
.git/
.github/
.venv/
venv/
__pycache__/
*.pyc
*.pyo

# Secrets — these MUST be set as HF Space env vars, not baked into the image
.streamlit/secrets.toml
users.yaml

# Local databases / runtime state
foundry.db
foundry.db-shm
foundry.db-wal
*.sqlite
*.sqlite3
.foundry/
# `files/` IS shipped — it contains the seed source PDFs that are tracked in
# git (force-added on top of .gitignore). Runtime uploads go to the same
# directory but live only in the running container.

# Editor / IDE
.vscode/
.idea/
.DS_Store
Thumbs.db

# Streamlit local cache
.streamlit/cache/

# Old data + migrations not needed at runtime
ParkerJones_PO_Samples/
samples/
*.xlsx

# Markdown / docs (not needed at runtime — README stays for HF metadata)
CHANGELOG.md
