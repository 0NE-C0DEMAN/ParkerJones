# =============================================================================
# users.yaml — Foundry invitation list (TEMPLATE)
# =============================================================================
# Copy to users.yaml and edit. users.yaml is gitignored — never commit real
# emails or your JWT secret to source control.
#
# Each entry under `invited` is allowed to self-register at /register with the
# matching email. Anyone NOT on this list will be rejected on registration.
#
# Roles:
#   admin — full access, sees the Team page
#   rep   — standard sales rep access (default)
# =============================================================================

invited:
  - email: admin@your-company.com
    role: admin
    name: Admin User

  # Add team members below. Example:
  # - email: rep1@your-company.com
  #   role: rep
  #   name: Jane Doe

# Behavioral settings
require_invitation: true   # if false, anyone can register (NOT recommended)
default_role: rep
session_days: 7            # how long JWT tokens stay valid

# JWT signing secret — the only thing preventing forged sessions.
# CHANGE THIS when you set up your own deployment. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
jwt_secret: "REPLACE-WITH-A-RANDOM-64-CHAR-HEX-STRING"
