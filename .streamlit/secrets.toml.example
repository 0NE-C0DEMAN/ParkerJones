# Copy this file to .streamlit/secrets.toml and fill in real values.
# secrets.toml is loaded by Streamlit at runtime and is never committed to git.

# Default OpenRouter key shipped to all users of this Streamlit deployment.
# Individual users can still override this in the in-app Settings panel
# (their override is saved to browser localStorage and takes precedence).
OPENROUTER_API_KEY = "sk-or-v1-..."
