# =============================================================================
# .streamlit/secrets.toml — local-only credentials & config
# =============================================================================
# Copy this file to .streamlit/secrets.toml and fill in real values.
# The real secrets.toml is gitignored — never commit it.
#
# In production (Hugging Face Spaces), set the same keys as Space "Variables
# and secrets" — env vars take precedence over this file.
# =============================================================================

# OpenRouter / Gemini API key — pasted into the React app at runtime as
# window.STREAMLIT_API_KEY so the frontend can call the LLM without
# anything hardcoded in JS.
OPENROUTER_API_KEY = "sk-or-v1-XXXXXXXX..."   # or AIza... for Gemini

# JWT signing secret. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FOUNDRY_JWT_SECRET = "replace-with-a-random-hex-string"

# Storage backend: "sqlite" (default — local foundry.db) or "turso" (cloud libSQL).
FOUNDRY_DB_BACKEND = "turso"

# Turso (libSQL) credentials — only required when FOUNDRY_DB_BACKEND = "turso".
# Create a free DB at https://turso.tech and grab these from the dashboard.
TURSO_DB_URL = "libsql://your-db-name.turso.io"
TURSO_DB_TOKEN = "eyJhbGciOiJFZERTQSIs..."
