# =============================================================================
# .streamlit/secrets.toml — local-only credentials & config
# =============================================================================
# Copy this file to .streamlit/secrets.toml and fill in real values.
# The real secrets.toml is gitignored — never commit it.
# =============================================================================

# OpenRouter / Gemini API key — pasted into the React app at runtime as
# window.STREAMLIT_API_KEY so the frontend can call the LLM without
# anything hardcoded in JS.
OPENROUTER_API_KEY = "AIzaSyXXXXXXXX..."   # or sk-or-v1-... for OpenRouter


# Pick the storage backend: "sqlite" (default) or "sheets"
FOUNDRY_DB_BACKEND = "sheets"


# Google Sheets backend — the spreadsheet ID (from its URL)
# https://docs.google.com/spreadsheets/d/{THIS_PART}/edit
FOUNDRY_SHEET_ID = "1AbCdEfGhIjKlMnOpQrStUvWxYz_replace_with_yours"


# Service account credentials for Sheets API.
# Paste the ENTIRE downloaded JSON here under [gcp_service_account].
# Every field from the JSON file goes in this section.
[gcp_service_account]
type = "service_account"
project_id = "foundry-parker"
private_key_id = "abc123..."
private_key = """-----BEGIN PRIVATE KEY-----
MIIEvQI....many lines....
-----END PRIVATE KEY-----
"""
client_email = "foundry-app@foundry-parker.iam.gserviceaccount.com"
client_id = "1234567890"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/foundry-app%40foundry-parker.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
